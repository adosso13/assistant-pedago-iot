.group ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
    overflow-y: auto;
}

.group li {
    padding: 8px;
    background: #343541;
    border-radius: 6px;
    cursor: pointer;
    
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.group li:hover {
    background: #444654;
}

/* MAIN */
.content {
    flex: 1;
    background-color: #f5f5f5;
    padding: 20px;
}